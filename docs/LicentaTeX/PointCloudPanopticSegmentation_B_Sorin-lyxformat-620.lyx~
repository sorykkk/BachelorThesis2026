\begin_layout Subsection
SCAN
\end_layout

\begin_layout Standard
Ansamblul de puncte are o natură 
\shape italic
rară
\shape default
 (puncte îndepărtate unele de altele),
 neordonată și eșantionată neregulat,
 agregată doar la suprafața obiectelor,
 formând,
 astfel,
 două provocări majore:
 (i) punctele agregate de pe suprafața obiectelor mari sunt deplasate unele de altele,
 provocând o segmentare eronată a acestor obiecte,
 (ii) obiectele mici distribuite aproape,
 sunt fals combinate,
 din cauza similarității în spațiul metric și cel de caracteristici.
 Gruparea corectă a punctelor prin învățarea eficientă a caracterisiticilor,
 ar duce la soluționarea mai multor sarcini importante în conducerea autonomă sau aplicații robotice.
\end_layout

\begin_layout Standard
Articolul propune o arhitectură nouă:
 Sparse Cross-scale Attention Network (SCAN) 
\begin_inset CommandInset citation
LatexCommand citep
key "SCAN"
literal "false"

\end_inset

 cu un mecanism nou de
\emph on
 atenție globală de scară largă
\emph default
.
 Rețeaua de bază transformă în pixeli volumetrici punctele 
\begin_inset Formula $P\in$
\end_inset


\begin_inset Formula $\mathbb{R}^{N\times4}$
\end_inset

,
 folosind dimensiunea voxelului 
\begin_inset Formula $s$
\end_inset

 și le codifică în caracteristicile rare 
\begin_inset Formula $R^{b_{n}}=\{I^{b_{n}}\in\mathbb{R}^{M\times3},F^{b_{n}}\in\mathbb{R}^{M\times C}\}$
\end_inset

,
 unde 
\begin_inset Formula $b_{n}$
\end_inset

 – blocul din cadrul rețelei,
 
\begin_inset Formula $n=\overline{1,4}$
\end_inset

,
 
\begin_inset Formula $I^{b_{n}}$
\end_inset

 – indecșii coordonatelor voxelilor valide de forma 
\begin_inset Formula $x'=\lfloor\frac{x}{s}\rfloor,$
\end_inset


\begin_inset Formula $y'=\lfloor\frac{y}{s}\rfloor$
\end_inset

,
 
\begin_inset Formula $z'=\lfloor\frac{z}{s}\rfloor$
\end_inset

,
 
\begin_inset Formula $F^{b_{n}}$
\end_inset

 – tensorul caracteristicilor care corespund 
\begin_inset Formula $I^{b_{n}}$
\end_inset

,
 
\begin_inset Formula $M$
\end_inset

 – numărul pixelilor volumetrice valide cu dimensiunea curentă și 
\begin_inset Formula $C$
\end_inset

 – numărul de canale a tensorului.
\end_layout

\begin_layout Standard

\shape italic
\emph on
Modulul de
\emph default
 atenție interscalară
\shape default
 ia 
\begin_inset Formula $R^{b_{n}}$
\end_inset

 la diferite scări 
\begin_inset Formula $2s$
\end_inset

,
 
\begin_inset Formula $4s$
\end_inset

 și diferite niveluri 
\begin_inset Formula $b_{2},$
\end_inset


\begin_inset Formula $b_{3},$
\end_inset


\begin_inset Formula $b_{4}$
\end_inset

 la intrare și la ieșire dă caracteristicile rare
\shape italic
,
 aliniate
\shape default
 la scara 
\begin_inset Formula $4s$
\end_inset

 și 
\shape italic
fuzionate 
\begin_inset Formula $A$
\end_inset


\shape default
,
 cu asocierea internă între voxeli păstrați de 
\shape italic
distribuția centroizilor rari în BEV
\shape default
,
 adoptată în locul versiunii dense,
 folosită în literatură până atunci.
\end_layout

\begin_layout Standard
Comparând cu cele mai performante modele ale perioadei respective,
 
\shape italic
SCAN 
\shape default
e cu 1.5% mai performant decât 
\shape italic
GP-S3NET 
\shape default

\begin_inset CommandInset citation
