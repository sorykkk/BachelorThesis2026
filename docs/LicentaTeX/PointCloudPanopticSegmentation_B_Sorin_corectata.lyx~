\begin_layout Plain Layout
Comparația blocului (a) arhitectura DyCo3D 
\begin_inset CommandInset citation
LatexCommand citep
key "Dyco3d"
literal "false"

\end_inset

 și a blocului (b) arhitectura generală ISBNet.
 
\begin_inset CommandInset citation
LatexCommand citep
key "ISBNet"
literal "false"

\end_inset

 
\begin_inset CommandInset label
LatexCommand label
name "fig:ISBNet"

\end_inset


